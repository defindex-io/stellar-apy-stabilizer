# ============================================================================
# APY Stabilizer Bot — environment template
#
# Copy to .env and fill in real values:
#     cp .env.example .env
#
# .env is gitignored. NEVER commit secrets.
# ============================================================================

# ---- Stellar / Soroban ----

# Mainnet Soroban RPC endpoint. Public options:
#   https://rpc.lightsail.network
#   https://soroban-rpc.creit.tech
# For production traffic use a paid / private RPC.
SOROBAN_RPC=https://rpc.lightsail.network

# ---- DeFindex Indexer (Postgres, read-only) ----

# Connection string for the DeFindex indexer Postgres (parsed.* schema).
# Use a read-only role — the bot only SELECTs.
INDEXER_DATABASE_URL=postgres://user:password@host:5432/indexer

# SSL is on by default with rejectUnauthorized=false (works with Cloud SQL,
# Supabase, Railway, etc.). Set to "false" ONLY for a local dev Postgres
# without SSL.
# INDEXER_DATABASE_SSL=false

# ---- FeeProxy fee_manager (Stellar) ----

# Stellar secret of the address registered as `fee_manager` on the FeeProxy
# contract. Used to sign lock_fees transactions. Treat as a hot key — minimal
# XLM balance, rotate via `set_fee_manager` if exposed.
FEE_MANAGER_SECRET_KEY=S_____________________________________________________

# Mainnet FeeProxy contract address. Optional — the bot ships with a hardcoded
# default in src/stabilizer/constants.ts. Set this only to override the default
# (e.g., after a FeeProxy redeployment).
# FEE_PROXY_ADDRESS_MAINNET=CDEFLWJMPR6DDNOEGP6KNPSPRWKPUG3DJLIOQZIS6EHIGNK7EGTQSA7R

# ---- Runtime flags ----

# When true, the bot computes every fee adjustment but SKIPS the lock_fees
# submission. Keep true for the first deploy, validate against the API's
# /vault-ops/stabilize/status response, then flip to false.
VAULT_OPS_DRY_RUN=true

# Interval between ticks, milliseconds. Default 3600000 (1 hour) matches the
# control loop's design. Tighten for local testing (e.g., 60000 = 1 min).
STABILIZER_INTERVAL_MS=3600000
